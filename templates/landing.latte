{layout 'layouts/landing.latte'}

{block content}
<main class="landing">
    {* ─── Inline SVG defs: the gold-seam gradient reused by every .seam-svg ─── *}
    <svg width="0" height="0" aria-hidden="true" focusable="false" style="position:absolute">
        <defs>
            <linearGradient id="seam-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%"   stop-color="oklch(0.78 0.13 75)" stop-opacity="0"/>
                <stop offset="20%"  stop-color="oklch(0.78 0.13 75)" stop-opacity="0.9"/>
                <stop offset="50%"  stop-color="oklch(0.72 0.13 75)" stop-opacity="1"/>
                <stop offset="80%"  stop-color="oklch(0.78 0.13 75)" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="oklch(0.78 0.13 75)" stop-opacity="0"/>
            </linearGradient>
        </defs>
    </svg>

    {* ─── 1. Hero ─── *}
    <section class="hero" id="hero">
        <div class="hero-grid">
            <div class="hero-content">
                <div class="hero-brand">
                    <span class="hero-brand-mark" aria-hidden="true">金</span>
                    <span class="hero-brand-text">Kintsugi</span>
                </div>
                <h1 class="hero-tagline">
                    Mend the wallet.<br>
                    <span class="accent">Keep the gold.</span>
                </h1>
                <p class="hero-sub">
                    {$leafDescription ?? 'Atomic, sweeper-proof wallet rescue using EIP-7702.'}
                    Open source. Runs locally. No fees, ever.
                </p>
                <div class="hero-cta-row">
                    <div class="install-box code-block-wrapper">
                        <span class="prompt">$</span>
                        <code id="install-cmd">npm install -g @ophelios/kintsugi-cli</code>
                        <button type="button" class="copy-btn" aria-label="Copy install command" onclick="
                            navigator.clipboard.writeText('npm install -g @ophelios/kintsugi-cli');
                            this.classList.add('copied');
                            setTimeout(() => this.classList.remove('copied'), 1600);
                        ">
                            <svg class="copy-icon" width="15" height="15" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M8 2a2 2 0 00-2 2v9a2 2 0 002 2h7a2 2 0 002-2V4a2 2 0 00-2-2H8zm-4 5a2 2 0 00-2 2v9a2 2 0 002 2h7a2 2 0 002-2v-1H8a3 3 0 01-3-3V7H4z"/></svg>
                            <svg class="copy-check" width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 10.5l3.5 3.5L16 5.5"/></svg>
                        </button>
                    </div>
                    <a href="{$leafBaseUrl}/getting-started/install/" class="btn-secondary">
                        Read the docs
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    {* ─── 2. The hostage problem ─── *}
    <section class="problem-section" id="problem">
        <div class="problem-grid">
            <div>
                <span class="section-eyebrow">The problem</span>
                <h2 class="section-title">Your keys are leaked. Your wallet is being watched.</h2>
                <p class="section-lede">
                    A sweeper bot now monitors the compromised address around the clock. The moment any ETH lands there to pay gas for a recovery transaction, the bot front-runs you and drains it in the same block. Tokens, NFTs, and ENS names sit visible but unreachable. Most rescues fail before they start.
                </p>
                <p class="problem-aside">
                    Kintsugi removes the gas dependency entirely. The victim wallet never holds ETH at any point. A separate rescuer wallet pays for and submits the recovery in one atomic Type-4 transaction, transferring every selected asset out before the sweeper sees an opening.
                </p>
            </div>
            <div>
                <figure class="attack-story" aria-label="The sweeper attack sequence">
                    <figcaption class="attack-story-eyebrow">The attack, in three beats</figcaption>
                    <ol class="attack-steps">
                        <li class="attack-step" data-step="1" style="--step-delay: 0s">
                            <span class="attack-step-index" aria-hidden="true">1</span>
                            <span class="attack-step-icon" aria-hidden="true">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><path d="M16 14.5h2"/><path d="M12 2v4"/><path d="M9 4l3 3 3-3"/></svg>
                            </span>
                            <div class="attack-step-body">
                                <p class="attack-step-title">You send ETH for gas</p>
                                <p class="attack-step-sub">0.01 ETH lands in the compromised wallet.</p>
                            </div>
                        </li>
                        <li class="attack-step is-attack" data-step="2" style="--step-delay: 2s">
                            <span class="attack-step-index" aria-hidden="true">2</span>
                            <span class="attack-step-icon" aria-hidden="true">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="7" width="16" height="11" rx="3"/><path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M12 3v4"/><path d="M8 18v2"/><path d="M16 18v2"/></svg>
                            </span>
                            <div class="attack-step-body">
                                <p class="attack-step-title">The sweeper bot grabs it instantly</p>
                                <p class="attack-step-sub">Front-runs in the same block. The 0.01 ETH is gone before you blink.</p>
                            </div>
                        </li>
                        <li class="attack-step is-attack" data-step="3" style="--step-delay: 4s">
                            <span class="attack-step-index" aria-hidden="true">3</span>
                            <span class="attack-step-icon" aria-hidden="true">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 8l8 8"/><path d="M16 8l-8 8"/></svg>
                            </span>
                            <div class="attack-step-body">
                                <p class="attack-step-title">Your rescue transaction reverts</p>
                                <p class="attack-step-sub">Out of gas. The transfers never run.</p>
                            </div>
                        </li>
                    </ol>
                    <div class="attack-result">
                        <span class="attack-result-icon" aria-hidden="true">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/><circle cx="12" cy="16" r="1.2" fill="currentColor"/></svg>
                        </span>
                        <div>
                            <p class="attack-result-title">Your assets remain trapped.</p>
                            <p class="attack-result-sub">Tokens, NFTs, and ENS names sit visible but unreachable. This is where Kintsugi steps in.</p>
                        </div>
                    </div>
                </figure>
            </div>
        </div>
    </section>

    {* ─── 2.5. Counter to the 7702-as-attack pattern ─── *}
    <section class="landing-section counter-section" id="counter">
        <span class="section-eyebrow">The attacker's other trick</span>
        <h2 class="section-title">When attackers use EIP-7702 against you, we use it back.</h2>
        <p class="section-lede">
            After a key compromise, attackers often install their own EIP-7702 delegation on your wallet, pointing it to an auto-drainer contract that triggers on any incoming funds, on any chain. Kintsugi's rescue uses the same primitive to overwrite their delegation, atomically, before our transaction does anything else.
        </p>
        <div class="counter-diagram">
            <div class="counter-side counter-side--attack reveal" style="--step-delay: 0s">
                <p class="counter-side-eyebrow">Their move</p>
                <h3 class="counter-side-title">Install an auto-drainer</h3>
                <ol class="counter-side-steps">
                    <li>
                        <span class="counter-side-num">1</span>
                        <span>Attacker has your private key.</span>
                    </li>
                    <li>
                        <span class="counter-side-num">2</span>
                        <span>Sign a 7702 authorization pointing your wallet at <code>AutoDrainer</code>.</span>
                    </li>
                    <li>
                        <span class="counter-side-num">3</span>
                        <span>Submit a Type-4 tx (attacker pays gas, no involvement from you).</span>
                    </li>
                </ol>
                <p class="counter-side-result">Any incoming ETH is auto-stolen in the same block. Across every chain the bot watches.</p>
            </div>
            <div class="counter-spark" aria-hidden="true">
                <svg class="counter-spark-seam seam-svg" viewBox="0 0 18 320" preserveAspectRatio="none">
                    <path d="M9 0 L 6 60 L 12 130 L 5 200 L 11 260 L 9 320" vector-effect="non-scaling-stroke"/>
                </svg>
                <span class="counter-spark-pulse"></span>
                <span class="counter-spark-label">The overwrite moment</span>
            </div>
            <div class="counter-side counter-side--defense reveal" style="--step-delay: 0.18s">
                <p class="counter-side-eyebrow">Our move</p>
                <h3 class="counter-side-title">Overwrite with the Rescue contract</h3>
                <ol class="counter-side-steps">
                    <li>
                        <span class="counter-side-num">1</span>
                        <span>Sign a new 7702 authorization at the <em>current</em> nonce, pointing to <code>Rescue</code>.</span>
                    </li>
                    <li>
                        <span class="counter-side-num">2</span>
                        <span>One Type-4 tx: our authorization processes first, overwriting theirs.</span>
                    </li>
                    <li>
                        <span class="counter-side-num">3</span>
                        <span>Then the same tx calls <code>Rescue.executeBatch</code> on your wallet.</span>
                    </li>
                </ol>
                <p class="counter-side-result">Their drainer never executes. Assets transferred atomically to your safe wallet.</p>
            </div>
        </div>
        <p class="counter-footnote">
            Newer EIP-7702 authorizations at the current nonce always win. That's the spec, not a workaround. Pair with <code>--private-mempool</code> when paranoia is warranted so the attacker can't even see our tx coming.
        </p>
    </section>

    {* ─── 3. What sweepers ignore (dark) ─── *}
    <section class="section-dark section-dark--a" id="coverage">
        <div class="landing-section">
            <span class="section-eyebrow">The recovery gap</span>
            <h2 class="section-title">They take what's liquid. They leave what's yours.</h2>
            <p class="section-lede">
                Drainer bots optimize for fast liquidation. They sweep ETH and the most liquid ERC-20s, ignore everything that takes effort to fence, and move on. The leftovers are often the most personally valuable holdings, but a working sweeper still blocks any normal recovery attempt.
            </p>
            <div class="leftbehind-stack">
                <article class="leftbehind-card reveal" style="--step-delay: 0s">
                    <span class="leftbehind-kanji" aria-hidden="true">字</span>
                    <p class="leftbehind-card-eyebrow">ENS name</p>
                    <p class="leftbehind-card-name">vitalik.eth</p>
                    <p class="leftbehind-card-tag">7-year hold <span class="dot">·</span> trapped</p>
                    <p class="leftbehind-card-note">Your dot-eth identity, used everywhere for years, is rarely auto-drained — and typically the hardest to move once a sweeper is watching. Kintsugi handles unwrapped 2LDs, wrapped names, and subdomains in a single batch.</p>
                </article>
                <article class="leftbehind-card reveal" style="--step-delay: 0.12s">
                    <span class="leftbehind-kanji" aria-hidden="true">画</span>
                    <p class="leftbehind-card-eyebrow">Illiquid NFT</p>
                    <p class="leftbehind-card-name is-display">BAYC #1234</p>
                    <p class="leftbehind-card-tag">ERC-721 <span class="dot">·</span> trapped</p>
                    <p class="leftbehind-card-note">Long-tail collections, art, in-game items, memberships. Bots usually skip ERC-721 and ERC-1155 — resale path's too slow. They stay visible, recoverable by no one.</p>
                </article>
                <article class="leftbehind-card reveal" style="--step-delay: 0.24s">
                    <span class="leftbehind-kanji" aria-hidden="true">小</span>
                    <p class="leftbehind-card-eyebrow">Low-cap token</p>
                    <p class="leftbehind-card-name">$AAVE — gov</p>
                    <p class="leftbehind-card-tag">vested position <span class="dot">·</span> trapped</p>
                    <p class="leftbehind-card-note">Reward tokens, governance positions, vested allocations — anything without a deep pool. Drainers ignore them, but you still can't reach them through a wallet the sweeper is gating.</p>
                </article>
                <div class="leftbehind-seam">
                    <svg class="seam-svg" viewBox="0 0 1000 320" preserveAspectRatio="none" aria-hidden="true">
                        <path d="M20 290 L 220 230 L 410 195 L 600 130 L 780 80 L 980 30" vector-effect="non-scaling-stroke"/>
                    </svg>
                </div>
            </div>
        </div>
    </section>

    {* ─── 4. How Kintsugi works (dark, slightly different shade) ─── *}
    <section class="section-dark section-dark--b" id="how">
        <div class="landing-section">
            <span class="section-eyebrow">How it works</span>
            <h2 class="section-title">One transaction. No gas from you. Nothing left behind.</h2>
            <p class="section-lede">
                EIP-7702 lets a victim wallet temporarily delegate execution to a battle-tested rescue contract. Combined with EIP-712 batch authorization, every selected asset moves to your safe wallet inside one atomic Type-4 transaction, paid for by a separate rescuer key.
            </p>
            <figure class="rescue-story rescue-story--horizontal" aria-label="The rescue sequence">
                <figcaption class="rescue-story-eyebrow">The rescue, in three beats</figcaption>
                <svg class="rescue-seam seam-svg" preserveAspectRatio="none" viewBox="0 0 1000 12" aria-hidden="true">
                    <path d="M0 6 L 150 4 L 320 8 L 500 5 L 680 9 L 840 5 L 1000 7"/>
                </svg>
                <ol class="rescue-steps rescue-steps--horizontal">
                    <li class="rescue-step reveal" data-step="1" style="--step-delay: 0s">
                        <span class="rescue-step-index" aria-hidden="true">1</span>
                        <div class="rescue-step-body">
                            <p class="rescue-step-title">You sign, locally.</p>
                            <p class="rescue-step-sub">EIP-7702 authorization + EIP-712 batch of transfers. Keys live in your local Node process only and are never written to disk.</p>
                        </div>
                    </li>
                    <li class="rescue-step reveal" data-step="2" style="--step-delay: 0.15s">
                        <span class="rescue-step-index" aria-hidden="true">2</span>
                        <div class="rescue-step-body">
                            <p class="rescue-step-title">Your rescuer submits one Type-4 tx.</p>
                            <p class="rescue-step-sub">A separate wallet you control pays the gas. Your authorization processes first, then it calls <code>Rescue.executeBatch</code>.</p>
                        </div>
                    </li>
                    <li class="rescue-step reveal" data-step="3" style="--step-delay: 0.3s">
                        <span class="rescue-step-index" aria-hidden="true">3</span>
                        <div class="rescue-step-body">
                            <p class="rescue-step-title">Every asset at your safe wallet.</p>
                            <p class="rescue-step-sub">Same block, atomic. The sweeper sees the tx land, finds the wallet empty, and moves on.</p>
                        </div>
                    </li>
                    <li class="rescue-step rescue-step--terminus reveal" style="--step-delay: 0.45s">
                        <span class="rescue-step-index rescue-step-index--terminus" aria-hidden="true">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6z"/><path d="M9 12l2.2 2.2L15 10"/></svg>
                        </span>
                        <div class="rescue-step-body">
                            <p class="rescue-step-title">Balance never rose above zero.</p>
                            <p class="rescue-step-sub">No opening for a sweeper, because there was nothing to take. After, optionally clear the delegation with <code>kintsugi revoke</code>.</p>
                        </div>
                    </li>
                </ol>
            </figure>
        </div>
    </section>

    {* ─── 5. The agentic way in: ask your agent ─── *}
    <section class="landing-section agent-section" id="agent">
        <span class="section-eyebrow">The agentic way in</span>
        <h2 class="section-title">In panic? Don't read. <span class="accent">Ask your agent.</span></h2>
        <p class="section-lede">
            Kintsugi ships a free agent skill following the <a href="https://agentskills.io" target="_blank" rel="noopener">agentskills.io</a> spec. Install it once and your favourite AI coding agent learns the three-wallet pattern, the ordering rules, and every gotcha. Then it walks you through a rescue in plain English.
        </p>

        <div class="agent-conversation" aria-label="Example conversation with an agent">
            <div class="chat-message chat-message--user reveal" style="--step-delay: 0s">
                <div class="chat-bubble">
                    <p class="chat-bubble-text">My wallet got drained but I have hostage assets there. Help me rescue them with Kintsugi.</p>
                    <button type="button" class="chat-bubble-copy" aria-label="Copy this prompt" onclick="
                        navigator.clipboard.writeText('My wallet got drained but I have hostage assets there. Help me rescue them with Kintsugi.');
                        this.classList.add('copied');
                        setTimeout(() => this.classList.remove('copied'), 1600);
                    ">
                        <svg class="copy-icon" width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M8 2a2 2 0 00-2 2v9a2 2 0 002 2h7a2 2 0 002-2V4a2 2 0 00-2-2H8zm-4 5a2 2 0 00-2 2v9a2 2 0 002 2h7a2 2 0 002-2v-1H8a3 3 0 01-3-3V7H4z"/></svg>
                        <svg class="copy-check" width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 10.5l3.5 3.5L16 5.5"/></svg>
                    </button>
                </div>
                <div class="chat-meta">
                    <span class="chat-avatar chat-avatar--user" aria-hidden="true">You</span>
                </div>
            </div>

            <div class="chat-message chat-message--agent reveal" style="--step-delay: 0.12s">
                <div class="chat-meta">
                    <span class="chat-avatar chat-avatar--agent" aria-hidden="true">金</span>
                </div>
                <div class="chat-bubble chat-bubble--agent">
                    <p class="chat-bubble-text">Got it. I'll walk you through this end to end. First, what chain is the compromised wallet on, and do you have a fresh wallet ready to receive the assets?</p>
                </div>
            </div>

            <div class="chat-message chat-message--user reveal" style="--step-delay: 0.24s">
                <div class="chat-bubble">
                    <p class="chat-bubble-text">Mainnet. I have a fresh wallet ready.</p>
                </div>
                <div class="chat-meta">
                    <span class="chat-avatar chat-avatar--user" aria-hidden="true">You</span>
                </div>
            </div>

            <div class="chat-message chat-message--agent reveal" style="--step-delay: 0.36s">
                <div class="chat-meta">
                    <span class="chat-avatar chat-avatar--agent" aria-hidden="true">金</span>
                </div>
                <div class="chat-bubble chat-bubble--agent">
                    <p class="chat-bubble-text">Good. Let's start with a read-only inventory of the compromised wallet — that tells us exactly what we'll batch into the rescue. Paste the victim address when you're ready.</p>
                    <p class="chat-bubble-meta">Powered by the Kintsugi agent skill</p>
                </div>
            </div>

            <div class="chat-message chat-message--agent reveal" style="--step-delay: 0.52s" aria-hidden="true">
                <div class="chat-meta">
                    <span class="chat-avatar chat-avatar--agent" aria-hidden="true">金</span>
                </div>
                <div class="chat-bubble chat-bubble--agent chat-bubble--typing" role="status" aria-label="Agent is typing">
                    <span class="typing-dots">
                        <span class="typing-dot"></span>
                        <span class="typing-dot"></span>
                        <span class="typing-dot"></span>
                    </span>
                </div>
            </div>
        </div>

        <div class="skill-sidecar">
            <div class="skill-sidecar-block">
                <p class="skill-sidecar-label">Install the skill once:</p>
                <div class="install-box install-box--wide code-block-wrapper">
                    <span class="prompt">$</span>
                    <code id="install-skill-cmd">npx skills add ophelios-studio/skills --skill kintsugi</code>
                    <button type="button" class="copy-btn" aria-label="Copy install command" onclick="
                        navigator.clipboard.writeText('npx skills add ophelios-studio/skills --skill kintsugi');
                        this.classList.add('copied');
                        setTimeout(() => this.classList.remove('copied'), 1600);
                    ">
                        <svg class="copy-icon" width="15" height="15" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M8 2a2 2 0 00-2 2v9a2 2 0 002 2h7a2 2 0 002-2V4a2 2 0 00-2-2H8zm-4 5a2 2 0 00-2 2v9a2 2 0 002 2h7a2 2 0 002-2v-1H8a3 3 0 01-3-3V7H4z"/></svg>
                        <svg class="copy-check" width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 10.5l3.5 3.5L16 5.5"/></svg>
                    </button>
                </div>
            </div>
            <div class="skill-sidecar-row">
                <a href="{$leafBaseUrl}/getting-started/with-an-agent/" class="btn-secondary skill-sidecar-cta">
                    See what else to ask
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                </a>
                <div class="skill-sidecar-works">
                    <p class="skill-sidecar-label">Works with:</p>
                    <ul class="agent-clients">
                        <li class="agent-client-chip">Claude Code</li>
                        <li class="agent-client-chip">Cursor</li>
                        <li class="agent-client-chip">Codex</li>
                        <li class="agent-client-chip">Cline</li>
                        <li class="agent-client-chip">Gemini CLI</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    {* ─── 5.5 UI / CLI showcase as real-feeling app windows ─── *}
    <section class="landing-section" id="try">
        <span class="section-eyebrow">Or do it yourself</span>
        <h2 class="section-title">A UI for panic. A CLI for power.</h2>
        <p class="section-lede">
            Same atomic flow under the hood, two surfaces to drive it. The web UI is launched from the CLI as a localhost server. The browser only sees session-bound addresses and signatures. Private keys never leave the local Node process.
        </p>
        <div class="usage-stage">
            <article class="usage-stage-card usage-stage-card--front reveal" style="--step-delay: 0s">
                <div class="window">
                    <div class="window-chrome">
                        <span class="window-dots" aria-hidden="true">
                            <span class="window-dot window-dot--red"></span>
                            <span class="window-dot window-dot--yellow"></span>
                            <span class="window-dot window-dot--green"></span>
                        </span>
                        <span class="window-title">127.0.0.1:38080</span>
                        <span class="window-spacer"></span>
                    </div>
                    <div class="window-body window-body--ui">
                        <img src="{$leafBaseUrl}/assets/images/ui/welcome.png" alt="Kintsugi web UI welcome screen with the Kintsugi wordmark and the tagline Mend the wallet, Keep the gold." loading="lazy" width="1440" height="900">
                    </div>
                </div>
                <div class="usage-card-meta">
                    <span class="usage-card-eyebrow">The web UI</span>
                    <h3 class="usage-card-title">Guided. Step by step.</h3>
                    <ul class="usage-card-bullets">
                        <li>Pick the network and your RPC.</li>
                        <li>Paste victim, safe, and rescuer wallets.</li>
                        <li>Pick what to rescue, sign, submit.</li>
                    </ul>
                    <a href="{$leafBaseUrl}/ui-walkthrough/network/" class="usage-card-cta">Walk through the UI →</a>
                </div>
            </article>

            <article class="usage-stage-card usage-stage-card--back reveal" style="--step-delay: 0.15s">
                <div class="window window--terminal">
                    <div class="window-chrome window-chrome--terminal">
                        <span class="window-dots" aria-hidden="true">
                            <span class="window-dot window-dot--red"></span>
                            <span class="window-dot window-dot--yellow"></span>
                            <span class="window-dot window-dot--green"></span>
                        </span>
                        <span class="window-title window-title--terminal">~  kintsugi rescue</span>
                        <span class="window-spacer"></span>
                    </div>
                    <div class="window-body window-body--terminal">
                        <pre class="window-terminal-pre"><span class="comment"># launch the guided localhost UI</span>
<span class="prompt">$</span> kintsugi ui

<span class="comment"># ...or do everything in the terminal</span>
<span class="prompt">$</span> kintsugi rescue

<span class="comment"># inspect a wallet read-only first</span>
<span class="prompt">$</span> kintsugi status 0xVictim...

<span class="comment"># after rescue, optionally clear delegation</span>
<span class="prompt">$</span> kintsugi revoke
<span class="cursor" aria-hidden="true">▍</span></pre>
                    </div>
                </div>
                <div class="usage-card-meta">
                    <span class="usage-card-eyebrow">The CLI</span>
                    <h3 class="usage-card-title">Headless. Scriptable.</h3>
                    <ul class="usage-card-bullets">
                        <li>One command (<code>kintsugi rescue</code>) walks you through.</li>
                        <li>Read-only inventory with <code>kintsugi status</code>.</li>
                        <li>Pipes well. No browser required.</li>
                    </ul>
                    <a href="{$leafBaseUrl}/cli-reference/rescue/" class="usage-card-cta">Read the CLI reference →</a>
                </div>
            </article>
        </div>
    </section>

    {* ─── 6. Open source manifesto (dark) ─── *}
    <section class="section-dark section-dark--a" id="open-wrap">
        <div class="landing-section" id="open">
            <div class="manifesto">
                <span class="section-eyebrow">Our stance</span>
                <p class="manifesto-lede">
                    A wallet rescue tool that charges money in the worst moment of someone's crypto life is a wallet rescue tool taking advantage of panic. We will not do that.
                </p>
            </div>
            <div class="manifesto-pillars">
                <div class="manifesto-pillar reveal" style="--step-delay: 0s">
                    <h3 class="manifesto-pillar-title">Open source.</h3>
                    <p class="manifesto-pillar-sub">MIT-licensed. Public repository. Every line auditable, every contract verified.</p>
                </div>
                <svg class="seam-rule seam-svg" preserveAspectRatio="none" viewBox="0 0 600 12" aria-hidden="true">
                    <path d="M4 7 L 120 5 L 250 8 L 380 5 L 510 8 L 596 6"/>
                </svg>
                <div class="manifesto-pillar reveal" style="--step-delay: 0.1s">
                    <h3 class="manifesto-pillar-title">No <span class="brush">fees.</span></h3>
                    <p class="manifesto-pillar-sub">No SaaS tier. No signup. No telemetry. Pay only your own gas.</p>
                </div>
                <svg class="seam-rule seam-svg" preserveAspectRatio="none" viewBox="0 0 600 12" aria-hidden="true">
                    <path d="M4 6 L 110 9 L 240 5 L 360 8 L 490 5 L 596 8"/>
                </svg>
                <div class="manifesto-pillar reveal" style="--step-delay: 0.2s">
                    <h3 class="manifesto-pillar-title">No upsell.</h3>
                    <p class="manifesto-pillar-sub">No premium features behind a paywall. The whole tool is the whole tool.</p>
                </div>
            </div>
            <aside class="manifesto-tip reveal" style="--step-delay: 0.3s" aria-label="Donations are welcome but never required">
                <p class="manifesto-tip-text">
                    Did Kintsugi rescue your assets? <span class="manifesto-tip-accent">Buy us a coffee.</span> Any token, any EVM chain. Optional — we'll never ask twice.
                </p>
                <div class="manifesto-tip-address">
                    <code id="donate-address">0x75866ab2AB70bc58c5d4086E0a7b4089224a6412</code>
                    <button type="button" class="manifesto-tip-copy" aria-label="Copy donation address" onclick="
                        navigator.clipboard.writeText('0x75866ab2AB70bc58c5d4086E0a7b4089224a6412');
                        this.classList.add('copied');
                        setTimeout(() => this.classList.remove('copied'), 1600);
                    ">
                        <svg class="copy-icon" width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M8 2a2 2 0 00-2 2v9a2 2 0 002 2h7a2 2 0 002-2V4a2 2 0 00-2-2H8zm-4 5a2 2 0 00-2 2v9a2 2 0 002 2h7a2 2 0 002-2v-1H8a3 3 0 01-3-3V7H4z"/></svg>
                        <svg class="copy-check" width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 10.5l3.5 3.5L16 5.5"/></svg>
                    </button>
                </div>
                <p class="manifesto-tip-note">Same wallet across every EVM chain. Tips are not tax-deductible donations, just a thank-you.</p>
            </aside>
            <div class="deployments-panel">
                <header class="deployments-panel-head">
                    <span class="deployments-panel-eyebrow">Deployments</span>
                    <span class="deployments-panel-links">
                        <a href="{$leafBaseUrl}/security/self-audit/" class="deployments-panel-source">
                            Read the self-audit
                            <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
